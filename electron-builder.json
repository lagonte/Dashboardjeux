{
  "appId": "fr.autocutter.dashboardjeux",
  "productName": "DashboardJeux",
  "main": "electron-main.js",
  "files": [
    "electron-main.js",
    "launcher.html",
    "server.js",
    "public/**/*",
    "app-config.json",
    "node_modules/**/*",
    "!node_modules/.bin/**",
    "!node_modules/electron/**",
    "!node_modules/electron-builder/**"
  ],
  "extraResources": [],
  "mac": {
    "target": "dmg",
    "category": "public.app-category.utilities",
    "arch": ["arm64", "x64"]
  },
  "win": {
    "target": "nsis",
    "arch": ["x64"]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false
  }
}
