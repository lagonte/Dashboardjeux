{
  "appId": "fr.autocutter.dashboardjeux",
  "productName": "DashboardJeux",
  "icon": "icon.icns",
  "asar": false,
  "files": [
    "electron-main.js",
    "launcher.html",
    "server.js",
    "public/**/*",
    "app-config.json",
    "node_modules/**/*",
    "!node_modules/.bin/**",
    "!node_modules/electron/**",
    "!node_modules/electron-builder/**"
  ],
  "extraResources": [],
  "mac": {
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "category": "public.app-category.utilities"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false
  }
}
